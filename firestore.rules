rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{walletAddress} {
      // Allow reading user profiles
      allow read: if true;

      // Allow creating/updating points and progress with basic validation
      allow write: if 
        request.resource.data.keys().hasAll(['totalPoints', 'lastSeen']) &&
        request.resource.data.totalPoints is number &&
        request.resource.data.totalPoints >= 0 &&
        // Allow updating progress fields and granular points
        (request.resource.data.keys().hasAny(['completedLevels', 'bestScores', 'levelPoints']) || true);
    }
  }
}
